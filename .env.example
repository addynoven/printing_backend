NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/poms

# JWT
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=8h

# AWS S3 (for PDF storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=poms-files

# Billing
RAW_BILL_PASSWORD=change_this
SHOP_GSTIN=
SHOP_NAME=
SHOP_ADDRESS=

# Reverse proxy trust (set to number of proxies, e.g. 1, or 'true')
TRUST_PROXY=

# CORS (set to frontend origin in production, e.g. https://poms.example.com)
CORS_ORIGIN=*
